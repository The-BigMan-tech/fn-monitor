  },
  "homepage": "https://github.com/Siubaak/sval#readme",
  "dependencies": {
    "@types/estree": "^1.0.8",
    "acorn": "^8.14.0",
    "chalk": "^5.6.2",
    "lru-cache": "^11.3.5",
    "meriyah": "^7.1.0"
  },
  "devDependencies": {
    "@swc/core": "^1.11.24",
    "@types/node": "^22.15.3",
    "@vitest/coverage-v8": "^3.1.2",
    "happy-dom": "^20.0.11",
