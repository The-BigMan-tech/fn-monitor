    "description": "An augmentation of the sval JS-in-JS interpreter to monitor functions as they execute.",
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "files": [
        "dist/**/*.js",
        "dist/**/*.d.ts",
        "ACKNOWLEDGEMENTS.md"
    ],
    "author":{
        "name":"typescript-guy",
        "url": "https://github.com/The-BigMan-tech"
    },
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/The-BigMan-tech/fn-monitor.git"
    },
    "keywords": [
        "javascript",
        "typescript",
        "function",
        "monitor",
        "interpreter"
    ],
    "scripts": {
