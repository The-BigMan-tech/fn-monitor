        "@swc/core": "^1.11.24",
        "@types/js-beautify": "^1.14.3",
        "@types/node": "^22.15.3",
        "@vitest/coverage-v8": "^3.1.2",
        "happy-dom": "^20.0.11",
        "rollup": "^4.62.2",
        "rollup-plugin-dts": "^6.4.1",
        "tsx": "^4.23.1",
        "vite": "^6.3.4",
        "vite-plugin-dts": "^4.5.3",
        "vitest": "^3.1.2"
    }
